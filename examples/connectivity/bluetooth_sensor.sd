// Bluetooth discovery, pairing, and BLE service.
//   spanda check examples/connectivity/bluetooth_sensor.sd

ble_service HeartRateSensor {
  uuid: "180D";
}

robot HealthBot {
  bluetooth {
    scan for devices where name matches /^sensor-/;
    pair trusted_only;
  }
  actuator wheels: DifferentialDrive;

  on bluetooth.device_connected { wheels.stop(); }

  behavior idle() { wheels.stop(); }
}

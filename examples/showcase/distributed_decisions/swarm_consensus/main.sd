//! Swarm consensus — trust-weighted voting for distributed recovery.

robot SwarmBot001 {
    local_decision_authority [delegate_task, redistribute_tasks];
}

robot SwarmBot002 {
    local_decision_authority [delegate_task, redistribute_tasks];
}

robot SwarmBot003 {
    local_decision_authority [delegate_task, redistribute_tasks];
}

continuity_policy SwarmConsensus {
    on coordinator.failed {
        promote backup coordinator;
        redistribute swarm tasks;
    }
}

fleet InspectionFleet {
    SwarmBot001;
    SwarmBot002;
    SwarmBot003;
}

swarm InspectionSwarm {
    fleet InspectionFleet;
    policy round_robin;
}

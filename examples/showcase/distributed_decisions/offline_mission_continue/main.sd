//! Offline mission continue — bounded offline autonomy.

robot Rover001 {
    local_decision_authority [continue_current_safe_mission, pause_mission, return_home];
}

offline_policy RoverOffline {
    max_duration = 30 min;
    allowed_actions [
        continue_current_safe_mission,
        return_home,
        pause_mission,
        enter_degraded_mode
    ];
    forbidden_actions [
        start_new_high_risk_mission,
        disable_safety,
        accept_unknown_device
    ];
}

mission_plan PatrolMission {
    step patrol_route_a;
}

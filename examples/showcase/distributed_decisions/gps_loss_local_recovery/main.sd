//! GPS loss local recovery — Layer 1 local entity decision tree.

robot Rover001 {
    local_decision_authority [sensor_failover, degraded_mode, return_home];
    sensor gps: GPS;
    mode degraded { }
    safety { max_speed = 1.0 m/s; }
    behavior patrol() {
        loop every 50ms { }
    }
}

decision_tree GPSLossRecovery local {
    when gps.status == Failed {
        if visual_odometry.available {
            switch_to visual_odometry;
            reduce_speed 0.5 m/s;
            enter degraded_mode;
        } else {
            pause_mission;
            enter safe_mode;
        }
    }
}
